SHIMLAYER_REPOSITORY=postgres
SHIMLAYER_DB_DSN=postgresql://shim:shim@localhost:5432/shimlayer
SHIMLAYER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SHIMLAYER_ADMIN_API_KEY=replace-admin-key

SHIMLAYER_WEBHOOK_SECRET=replace-me
SHIMLAYER_WEBHOOK_TIMEOUT_SECONDS=5
SHIMLAYER_WEBHOOK_MAX_ATTEMPTS=5
SHIMLAYER_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

SHIMLAYER_RETENTION_WEBHOOK_DELIVERIES_DAYS=30
SHIMLAYER_RETENTION_SUCCEEDED_JOBS_DAYS=7
SHIMLAYER_RETENTION_API_RATE_WINDOWS_HOURS=48

# Stripe (optional)
SHIMLAYER_STRIPE_SECRET_KEY=
SHIMLAYER_STRIPE_PUBLISHABLE_KEY=
SHIMLAYER_STRIPE_WEBHOOK_SECRET=
SHIMLAYER_STRIPE_API_BASE=https://api.stripe.com

# Ops scripts
SHIMLAYER_API_URL=http://localhost:8000
SHIMLAYER_API_KEY=ops-checker
SHIMLAYER_SIGNOFF_PATH=docs/alpha-signoff-report.md
